---
import "../styles/global.css";
---

<header class="sticky top-0 z-50 border-b border-brand-sand/30 bg-brand-cream/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 relative">
    <a href="/" class="flex items-center no-underline">
      <img src="/images/moss-ai-studio-logo.jpg" alt="Moss AI Studio" class="h-12 w-auto md:h-14" />
    </a>

    <nav class="absolute left-1/2 hidden -translate-x-1/2 items-center gap-6 md:flex">
      <a href="#services" class="text-sm text-brand-earth/50 transition-colors hover:text-brand-earth">Services</a>
      <a href="#about" class="text-sm text-brand-earth/50 transition-colors hover:text-brand-earth">About</a>
      <a href="#faq" class="text-sm text-brand-earth/50 transition-colors hover:text-brand-earth">FAQ</a>
    </nav>

    <a
      href="#cta"
      class="inline-flex items-center gap-1.5 rounded-full border border-brand-sand/60 bg-brand-earth px-5 py-2.5 text-sm font-medium text-brand-cream transition-all duration-200 hover:bg-brand-olive hover:border-brand-olive hover:shadow-sm"
    >
      Book Free Consultation
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 0 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 0 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</header>
