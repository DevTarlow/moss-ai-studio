<header id="site-header" class="fixed top-0 right-0 left-0 z-50 transition-all duration-300 bg-transparent border-b border-transparent md:right-12">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center no-underline">
      <img src="/images/moss_ball_logo.png" alt="Moss AI Studio" class="mr-2 h-6 w-auto" />
      <span class="font-display text-xl font-bold text-[var(--color-text)]">Moss <span class="text-[var(--color-accent)]">AI</span> Studio</span>
    </a>

    <nav class="absolute left-1/2 hidden -translate-x-1/2 items-center gap-8 md:flex">
      <a href="/apps/" class="text-sm font-semibold text-[var(--color-text)]/60 transition-colors hover:text-[var(--color-text)]">Products</a>
      <a href="/blog/" class="text-sm font-semibold text-[var(--color-text)]/60 transition-colors hover:text-[var(--color-text)]">Blog</a>
      <a href="/#builds" class="text-sm font-semibold text-[var(--color-text)]/60 transition-colors hover:text-[var(--color-text)]">Custom Builds</a>
      <a href="/#about" class="text-sm font-semibold text-[var(--color-text)]/60 transition-colors hover:text-[var(--color-text)]">About</a>
      <a href="/#faq" class="text-sm font-semibold text-[var(--color-text)]/60 transition-colors hover:text-[var(--color-text)]">FAQ</a>
    </nav>

    <a
      href="/#cta"
      class="inline-flex items-center gap-1.5 bg-[var(--color-accent)] px-5 py-2.5 text-sm font-bold uppercase tracking-wide text-[#0F172A] transition-all duration-200 hover:bg-[var(--color-accent-hover)] hover:scale-[1.02]"
    >
      Book a Call
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 0 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 0 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</header>

<script>
  (function () {
    const header = document.getElementById("site-header");
    if (!header) return;

    function update() {
      if (!header) return;
      const scrolled = window.scrollY > 60;
      if (scrolled) {
        header.classList.add("bg-white/90", "backdrop-blur-md", "shadow-sm");
        header.classList.remove("bg-transparent");
        header.style.borderColor = "var(--color-border)";
      } else {
        header.classList.remove("bg-white/90", "backdrop-blur-md", "shadow-sm");
        header.classList.add("bg-transparent");
        header.style.borderColor = "transparent";
      }
    }

    window.addEventListener("scroll", update, { passive: true });
    update();
  })();
</script>
