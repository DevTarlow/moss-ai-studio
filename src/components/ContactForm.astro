<section id="contact" class="mx-auto max-w-6xl px-6 py-24">
  <div class="mx-auto max-w-2xl">
    <div class="mb-10 text-center">
      <p class="mb-3 font-mono text-xs font-medium uppercase tracking-[0.2em] text-brand-olive">Get In Touch</p>
      <h2 class="font-display text-3xl font-semibold tracking-tight text-brand-earth md:text-4xl">
        Tell us about your project.
      </h2>
      <p class="mt-3 text-brand-earth/60">
        Fill out the form below and we'll get back to you within 24 hours.
      </p>
    </div>

    <form id="contact-form"
      action="https://api.web3forms.com/submit"
      method="POST"
      class="reveal space-y-6"
    >
      <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
      <div>
        <label for="name" class="mb-2 block text-sm font-medium text-brand-earth/70">
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Jane Smith"
          class="w-full rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
        />
      </div>

      <div>
        <label for="email" class="mb-2 block text-sm font-medium text-brand-earth/70">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="jane@company.com"
          class="w-full rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
        />
      </div>

      <div>
        <label for="company" class="mb-2 block text-sm font-medium text-brand-earth/70">
          Company <span class="text-brand-sand/60">(optional)</span>
        </label>
        <input
          type="text"
          id="company"
          name="company"
          placeholder="Acme Inc."
          class="w-full rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
        />
      </div>

      <div>
        <label for="message" class="mb-2 block text-sm font-medium text-brand-earth/70">
          What are you looking to automate or build?
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="4"
          placeholder="Tell us a little about your workflows, tools, and goals..."
          class="w-full resize-y rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
        ></textarea>
      </div>

      <button
        type="submit"
        class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-transparent bg-brand-earth px-7 py-3.5 text-sm font-medium text-brand-cream transition-all duration-200 hover:bg-brand-olive hover:shadow-sm sm:w-auto sm:px-10"
      >
        Send Message
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path d="M3.105 2.288a.75.75 0 0 0-.826.95l1.414 4.926A1.5 1.5 0 0 0 5.135 9.25h6.115a.75.75 0 0 1 0 1.5H5.135a1.5 1.5 0 0 0-1.442 1.086l-1.414 4.926a.75.75 0 0 0 .826.95 28.896 28.896 0 0 0 15.293-7.155.75.75 0 0 0 0-1.114A28.897 28.897 0 0 0 3.105 2.288Z" />
        </svg>
      </button>

      <div id="form-status" class="mt-6 hidden text-center text-sm"></div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  const button = form.querySelector('button[type="submit"]');
  const buttonOriginalContent = button.innerHTML;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    status.classList.add('hidden');
    status.textContent = '';
    status.className = 'mt-6 hidden text-center text-sm';

    button.disabled = true;
    button.innerHTML = 'Sending...';
    button.classList.add('opacity-70', 'cursor-not-allowed');

    try {
      const data = new FormData(form);
      const body = new URLSearchParams(data);

      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      });

      if (!res.ok) throw new Error('Server responded with ' + res.status);

      status.textContent = 'Thanks! We\'ll get back to you within 24 hours.';
      status.className = 'mt-6 text-center text-sm text-green-600';
      form.reset();
    } catch (err) {
      status.textContent = 'Something went wrong. Please try again or email us directly.';
      status.className = 'mt-6 text-center text-sm text-red-500';
    } finally {
      status.classList.remove('hidden');
      button.disabled = false;
      button.innerHTML = buttonOriginalContent;
      button.classList.remove('opacity-70', 'cursor-not-allowed');
    }
  });
</script>
