---
const { activeTab = "book" } = Astro.props;
---

<section id="cta" class="mx-auto max-w-6xl px-6 py-24">
  <div class="mx-auto max-w-2xl text-center reveal">
    <p class="mb-3 font-mono text-xs font-medium uppercase tracking-[0.2em] text-brand-olive">Get Started</p>
    <h2 class="font-display text-3xl font-semibold tracking-tight text-brand-earth md:text-4xl">
      Book a <span class="italic text-brand-olive">30-Minute Consultation</span> 
    </h2>
    <p class="mt-3 text-brand-earth/60">
      Choose a time that works for you on the calendar. Or send a message to get in touch.
    </p>
  </div>

  <div class="cta-tabs mx-auto mt-10 max-w-2xl">
    <div class="mb-8 flex justify-center gap-2 rounded-xl border border-brand-sand/30 bg-brand-tan/30 p-1.5">
      <button
        class="cta-tab flex-1 rounded-lg px-4 py-2.5 text-sm font-medium transition-all duration-200"
        data-tab="book"
        aria-selected="true"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="-mt-0.5 mr-1.5 inline h-4 w-4">
          <path d="M10.362 1.093a.75.75 0 0 0-.724 0L2.523 5.018 10 9.143l7.477-4.125-7.115-3.925ZM18 6.443l-7.25 4v8.25l6.862-3.786A.75.75 0 0 0 18 14.25V6.443ZM9.25 18.693v-8.25l-7.25-4v7.807a.75.75 0 0 0 .388.657l6.862 3.786Z" />
        </svg>
        Book a Call
      </button>
      <button
        class="cta-tab flex-1 rounded-lg px-4 py-2.5 text-sm font-medium text-brand-earth/50 transition-all duration-200"
        data-tab="message"
        aria-selected="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="-mt-0.5 mr-1.5 inline h-4 w-4">
          <path d="M3.105 2.288a.75.75 0 0 0-.826.95l1.414 4.926A1.5 1.5 0 0 0 5.135 9.25h6.115a.75.75 0 0 1 0 1.5H5.135a1.5 1.5 0 0 0-1.442 1.086l-1.414 4.926a.75.75 0 0 0 .826.95 28.896 28.896 0 0 0 15.293-7.155.75.75 0 0 0 0-1.114A28.897 28.897 0 0 0 3.105 2.288Z" />
        </svg>
        Send a Message
      </button>
    </div>

    <div class="cta-panel" data-panel="book">
      <div class="rounded-2xl border border-brand-sand/40 bg-brand-cream p-6 md:p-8">
        <p class="mb-4 text-center text-sm text-brand-earth/60">
          Pick a time that works. No commitment, no pitch deck - just a conversation.
        </p>
        <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline-30min"></div>
        <script is:inline>
          (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
          Cal("init", "30min", {origin:"https://app.cal.com"});
          Cal.config = Cal.config || {};
          Cal.config.forwardQueryParams = true;
          Cal.ns["30min"]("inline", {
            elementOrSelector:"#my-cal-inline-30min",
            config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
            calLink: "moss-ai-studio/30min",
          });
          Cal.ns["30min"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
        </script>
      </div>
    </div>

    <div class="cta-panel hidden" data-panel="message">
      <div class="rounded-2xl border border-brand-sand/40 bg-brand-cream p-6 md:p-8">
        <form
          action="https://your-n8n-webhook.example.com/webhook/replace-me"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label for="cta-name" class="mb-1.5 block text-sm font-medium text-brand-earth/70">Name</label>
            <input
              type="text"
              id="cta-name"
              name="name"
              required
              placeholder="Jane Smith"
              class="w-full rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
            />
          </div>
          <div>
            <label for="cta-email" class="mb-1.5 block text-sm font-medium text-brand-earth/70">Email</label>
            <input
              type="email"
              id="cta-email"
              name="email"
              required
              placeholder="jane@company.com"
              class="w-full rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
            />
          </div>
          <div>
            <label for="cta-company" class="mb-1.5 block text-sm font-medium text-brand-earth/70">Company <span class="text-brand-sand/60">(optional)</span></label>
            <input
              type="text"
              id="cta-company"
              name="company"
              placeholder="Acme Inc."
              class="w-full rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
            />
          </div>
          <div>
            <label for="cta-message" class="mb-1.5 block text-sm font-medium text-brand-earth/70">What are you looking to automate or build?</label>
            <textarea
              id="cta-message"
              name="message"
              required
              rows="4"
              placeholder="Tell us a little about your workflows, tools, and goals..."
              class="w-full resize-y rounded-xl border border-brand-sand/40 bg-brand-cream px-4 py-3 text-sm text-brand-earth placeholder:text-brand-sand/80 transition-all duration-200 focus:border-brand-olive/50 focus:outline-none focus:ring-2 focus:ring-brand-olive/10"
            ></textarea>
          </div>
          <button
            type="submit"
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-brand-earth px-7 py-3.5 text-sm font-medium text-brand-cream transition-all duration-200 hover:bg-brand-olive hover:shadow-sm"
          >
            Send Message
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
              <path d="M3.105 2.288a.75.75 0 0 0-.826.95l1.414 4.926A1.5 1.5 0 0 0 5.135 9.25h6.115a.75.75 0 0 1 0 1.5H5.135a1.5 1.5 0 0 0-1.442 1.086l-1.414 4.926a.75.75 0 0 0 .826.95 28.896 28.896 0 0 0 15.293-7.155.75.75 0 0 0 0-1.114A28.897 28.897 0 0 0 3.105 2.288Z" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const tabs = document.querySelectorAll<HTMLElement>(".cta-tab");
    const panels = document.querySelectorAll<HTMLElement>(".cta-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.tab;

        tabs.forEach((t) => {
          t.setAttribute("aria-selected", "false");
          t.classList.remove("bg-brand-cream", "text-brand-earth", "shadow-sm");
          t.classList.add("text-brand-earth/50");
        });
        tab.setAttribute("aria-selected", "true");
        tab.classList.remove("text-brand-earth/50");
        tab.classList.add("bg-brand-cream", "text-brand-earth", "shadow-sm");

        panels.forEach((p) => {
          p.classList.toggle("hidden", p.dataset.panel !== target);
        });
      });
    });
  })();
</script>
