<section id="cta" class="bg-gradient-to-br from-[#DCE8F5] via-[#E8F0FE] to-[#DCE8F5] py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center reveal">
      <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">Let's Build Something Amazing</p>
      <h2 class="font-display text-3xl font-bold tracking-tight text-[var(--color-text)] md:text-4xl">
        Book a Call or Send a Message.
      </h2>
      <p class="mt-3 text-[var(--color-text-muted)]">
        Book a free 30-minute call or send a message. No commitment - just a conversation.
      </p>
    </div>

    <div class="cta-tabs mx-auto mt-10 max-w-2xl">
      <div role="tablist" class="mb-8 flex justify-center gap-2 rounded-xl border border-[var(--color-border)] bg-white/60 p-1.5 backdrop-blur-sm">
        <button
          role="tab"
          id="cta-tab-book"
          class="cta-tab flex-1 rounded-lg px-4 py-2.5 text-sm font-semibold transition-all duration-200"
          data-tab="book"
          aria-selected="true"
          aria-controls="cta-panel-book"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="-mt-0.5 mr-1.5 inline h-4 w-4">
            <path d="M10.362 1.093a.75.75 0 0 0-.724 0L2.523 5.018 10 9.143l7.477-4.125-7.115-3.925ZM18 6.443l-7.25 4v8.25l6.862-3.786A.75.75 0 0 0 18 14.25V6.443ZM9.25 18.693v-8.25l-7.25-4v7.807a.75.75 0 0 0 .388.657l6.862 3.786Z" />
          </svg>
          Book a Call
        </button>
        <button
          role="tab"
          id="cta-tab-message"
          class="cta-tab flex-1 rounded-lg px-4 py-2.5 text-sm font-semibold text-[var(--color-text-muted)] transition-all duration-200"
          data-tab="message"
          aria-selected="false"
          aria-controls="cta-panel-message"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="-mt-0.5 mr-1.5 inline h-4 w-4">
            <path d="M3.105 2.288a.75.75 0 0 0-.826.95l1.414 4.926A1.5 1.5 0 0 0 5.135 9.25h6.115a.75.75 0 0 1 0 1.5H5.135a1.5 1.5 0 0 0-1.442 1.086l-1.414 4.926a.75.75 0 0 0 .826.95 28.896 28.896 0 0 0 15.293-7.155.75.75 0 0 0 0-1.114A28.897 28.897 0 0 0 3.105 2.288Z" />
          </svg>
          Send a Message
        </button>
      </div>

      <div role="tabpanel" id="cta-panel-book" class="cta-panel" data-panel="book" aria-labelledby="cta-tab-book">
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 shadow-sm md:p-8">
          <p class="mb-4 text-center text-sm text-[var(--color-text-muted)]">
            Pick a time that works. No commitment - just a conversation.
          </p>
          <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline-30min"></div>
          <script is:inline>
            (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
            Cal("init", "30min", {origin:"https://app.cal.com"});
            Cal.config = Cal.config || {};
            Cal.config.forwardQueryParams = true;
            Cal.ns["30min"]("inline", {
              elementOrSelector:"#my-cal-inline-30min",
              config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
              calLink: "moss-ai-studio/30min",
            });
            Cal.ns["30min"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
          </script>
        </div>
      </div>

      <div role="tabpanel" id="cta-panel-message" class="cta-panel hidden" data-panel="message" aria-labelledby="cta-tab-message">
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 shadow-sm md:p-8">
          <form
            id="cta-form"
            action="/api/contact"
            method="POST"
            class="space-y-5"
          >
            <div>
              <label for="cta-name" class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]">Name</label>
              <input
                type="text"
                id="cta-name"
                name="name"
                required
                placeholder="Jane Smith"
                class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-muted)]/50 transition-all duration-200 focus:border-[var(--color-accent-2)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-2)]/10"
              />
            </div>
            <div>
              <label for="cta-email" class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]">Email</label>
              <input
                type="email"
                id="cta-email"
                name="email"
                required
                placeholder="jane@company.com"
                class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-muted)]/50 transition-all duration-200 focus:border-[var(--color-accent-2)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-2)]/10"
              />
            </div>
            <div>
              <label for="cta-company" class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]">Company <span class="text-[var(--color-text-muted)]">(optional)</span></label>
              <input
                type="text"
                id="cta-company"
                name="company"
                placeholder="Acme Inc."
                class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-muted)]/50 transition-all duration-200 focus:border-[var(--color-accent-2)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-2)]/10"
              />
            </div>
            <div>
              <label for="cta-message" class="mb-1.5 block text-sm font-semibold text-[var(--color-text)]">What are you looking to automate or build?</label>
              <textarea
                id="cta-message"
                name="message"
                required
                rows="4"
                placeholder="Tell me a little about your workflows, tools, and goals..."
                class="w-full resize-y rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-sm text-[var(--color-text)] placeholder:text-[var(--color-text-muted)]/50 transition-all duration-200 focus:border-[var(--color-accent-2)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-2)]/10"
              ></textarea>
            </div>
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center gap-2 bg-[var(--color-accent)] px-7 py-3.5 text-sm font-bold uppercase tracking-wide text-[#0F172A] transition-all duration-200 hover:bg-[var(--color-accent-hover)] hover:scale-[1.01]"
            >
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                <path d="M3.105 2.288a.75.75 0 0 0-.826.95l1.414 4.926A1.5 1.5 0 0 0 5.135 9.25h6.115a.75.75 0 0 1 0 1.5H5.135a1.5 1.5 0 0 0-1.442 1.086l-1.414 4.926a.75.75 0 0 0 .826.95 28.896 28.896 0 0 0 15.293-7.155.75.75 0 0 0 0-1.114A28.897 28.897 0 0 0 3.105 2.288Z" />
              </svg>
            </button>
            <div id="cta-form-status" class="mt-6 hidden text-center text-sm"></div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const ctaForm = document.getElementById('cta-form');
    if (ctaForm) {
      const ctaStatus = document.getElementById('cta-form-status');
      const ctaButton = ctaForm.querySelector('button[type="submit"]');
      const ctaBtnOriginal = ctaButton.innerHTML;

      ctaForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        ctaStatus.classList.add('hidden');
        ctaStatus.textContent = '';
        ctaStatus.className = 'mt-6 hidden text-center text-sm';
        ctaButton.disabled = true;
        ctaButton.innerHTML = 'Sending...';
        ctaButton.classList.add('opacity-70', 'cursor-not-allowed');

        try {
          const data = new FormData(ctaForm);
          const body = new URLSearchParams(data);
          const res = await fetch(ctaForm.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body,
          });
          if (!res.ok) throw new Error('Server responded with ' + res.status);
          ctaStatus.textContent = 'Thanks! I\'ll get back to you within 24 hours.';
          ctaStatus.className = 'mt-6 text-center text-sm text-[var(--color-accent)]';
          ctaForm.reset();
        } catch (err) {
          ctaStatus.textContent = 'Something went wrong. Please try again or email me directly.';
          ctaStatus.className = 'mt-6 text-center text-sm text-red-500';
        } finally {
          ctaStatus.classList.remove('hidden');
          ctaButton.disabled = false;
          ctaButton.innerHTML = ctaBtnOriginal;
          ctaButton.classList.remove('opacity-70', 'cursor-not-allowed');
        }
      });
    }

    const tabs = Array.from(document.querySelectorAll<HTMLElement>(".cta-tab"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>(".cta-panel"));

    function activateTab(tab: HTMLElement) {
      const target = tab.dataset.tab;

      tabs.forEach((t) => {
        t.setAttribute("aria-selected", "false");
        t.classList.remove("bg-white", "text-[var(--color-text)]", "shadow-sm");
        t.classList.add("text-[var(--color-text-muted)]");
      });
      tab.setAttribute("aria-selected", "true");
      tab.classList.remove("text-[var(--color-text-muted)]");
      tab.classList.add("bg-white", "text-[var(--color-text)]", "shadow-sm");

      panels.forEach((p) => {
        p.classList.toggle("hidden", p.dataset.panel !== target);
      });
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => activateTab(tab));

      tab.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight") {
          e.preventDefault();
          const next = (i + 1) % tabs.length;
          tabs[next].focus();
          activateTab(tabs[next]);
        }
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          const prev = (i - 1 + tabs.length) % tabs.length;
          tabs[prev].focus();
          activateTab(tabs[prev]);
        }
      });
    });
  })();
</script>
