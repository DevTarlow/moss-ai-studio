---
import { faqs } from "../data/faqs.js";

const categories = [
  { key: "products", label: "Products & Licensing" },
  { key: "builds", label: "Custom Builds" },
  { key: "general", label: "General" },
];
---

<section id="faq" class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl">
      <div class="mb-10 text-center reveal">
        <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">FAQ</p>
        <h2 class="font-display text-3xl font-bold tracking-tight text-[var(--color-text)] md:text-4xl">
          Common Questions.
        </h2>
        <p class="mt-3 text-sm text-[var(--color-text-muted)]">
          People and clients usually ask me.
        </p>
      </div>

      <div class="faq-filters mb-8 flex flex-wrap justify-center gap-2">
        {categories.map((cat) => (
          <button
            class="faq-filter rounded-full border border-[var(--color-border)] px-4 py-2 text-xs font-semibold text-[var(--color-text-muted)] transition-all duration-200 hover:border-[var(--color-accent-2)] hover:text-[var(--color-accent-2)]"
            data-category={cat.key}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div class="space-y-3 reveal">
        {faqs.map((faq) => (
          <div class="faq-item rounded-xl border border-[var(--color-border)] bg-white px-6 py-4 transition-all duration-200 hover:border-[var(--color-accent-2)]/40" data-category={faq.category}>
            <button
              class="faq-toggle flex w-full items-center justify-between gap-4 text-left"
              aria-expanded="false"
            >
              <span class="text-sm font-semibold text-[var(--color-text)]">{faq.q}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="faq-chevron h-4 w-4 flex-shrink-0 text-[var(--color-accent-2)] transition-transform duration-300">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </button>
            <div class="faq-content grid transition-all duration-300" style="grid-template-rows: 0fr;">
              <div class="overflow-hidden">
                <p class="pb-2 pt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".faq-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const content = btn.nextElementSibling;
      const chevron = btn.querySelector(".faq-chevron");
      const expanded = btn.getAttribute("aria-expanded") === "true";

      btn.setAttribute("aria-expanded", String(!expanded));
      content.style.gridTemplateRows = !expanded ? "1fr" : "0fr";
      if (chevron) chevron.classList.toggle("rotate-180");
    });
  });

  document.querySelectorAll(".faq-filter").forEach((filter) => {
    filter.addEventListener("click", () => {
      const category = filter.dataset.category;
      const wasActive = filter.classList.contains("!bg-[var(--color-accent-2)]");

      document.querySelectorAll(".faq-filter").forEach((f) => {
        f.classList.remove("!bg-[var(--color-accent-2)]", "!text-white", "!border-[var(--color-accent-2)]");
      });

      if (!wasActive) {
        filter.classList.add("!bg-[var(--color-accent-2)]", "!text-white", "!border-[var(--color-accent-2)]");

        document.querySelectorAll(".faq-item").forEach((item) => {
          const itemCat = item.dataset.category;
          if (itemCat === category) {
            (item as HTMLElement).style.display = "";
          } else {
            (item as HTMLElement).style.display = "none";
          }
        });
      } else {
        document.querySelectorAll(".faq-item").forEach((item) => {
          (item as HTMLElement).style.display = "";
        });
      }
    });
  });
</script>
