---
const faqs = [
  {
    q: "How long does a typical project take?",
    a: "Most projects run between 1 to 4 weeks depending on complexity. A single automated workflow can be developed in 3 to 5 days, while a bespoke AI application typically takes 2 to 4 weeks. You'll receive a firm, transparent timeline right during our initial discovery call."
  },
  {
    q: "Do you work with my existing stack?",
    a: "Almost certainly. We design digital ecosystems to integrate seamlessly with your existing tools. If your CRM, database, or software platform has an API, we can connect it. We specialize in n8n, OpenAI, databases, and major SaaS platforms, adapting naturally to whatever tech stack your business runs on."
  },
  {
    q: "What happens after you ship?",
    a: "You get full, complete ownership of your infrastructure and code. We don't believe in black boxes, and we provide clear, accessible documentation so your team can effortlessly run and maintain the ecosystem. If you ever need fine-tuning down the line, we offer flexible, hourly support blocks with zero retainer lock-in."
  },
  {
    q: "Do you only work with startups?",
    a: "Startups and lean small businesses are our absolute sweet spot. However, we partner with teams of any size that appreciate direct developer communication, fast shipping, and a small-studio approach that skips the corporate games."
  }
];
---

<section id="faq" class="mx-auto max-w-6xl px-6 py-24">
  <div class="mx-auto max-w-2xl reveal">
    <div class="mb-10 text-center">
      <p class="mb-3 font-mono text-xs font-medium uppercase tracking-[0.2em] text-brand-olive">FAQ</p>
      <h2 class="font-display text-3xl font-semibold tracking-tight text-brand-earth md:text-4xl">
        Common <span class="italic text-brand-olive">questions.</span>
      </h2>
    </div>

    <div class="space-y-3 reveal">
      {faqs.map((faq, i) => (
        <div class="faq-item rounded-2xl border border-brand-sand/30 bg-brand-cream px-6 py-4 transition-all duration-200">
          <button
            class="faq-toggle flex w-full items-center justify-between gap-4 text-left"
            aria-expanded="false"
          >
            <span class="text-sm font-medium text-brand-earth">{faq.q}</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="faq-chevron h-4 w-4 flex-shrink-0 text-brand-sand/60 transition-transform duration-300">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
          <div class="faq-content hidden">
            <p class="pb-2 pt-3 text-sm leading-relaxed text-brand-earth/60">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".faq-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const content = btn.nextElementSibling;
      const chevron = btn.querySelector(".faq-chevron");
      const expanded = btn.getAttribute("aria-expanded") === "true";

      btn.setAttribute("aria-expanded", String(!expanded));
      content?.classList.toggle("hidden");
      chevron?.classList.toggle("rotate-180");
    });
  });
</script>
