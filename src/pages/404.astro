---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
---

<Layout
  title="Page Not Found — Moss AI Studio"
  description="The page you're looking for doesn't exist."
  canonical="https://mossaistudio.com/404"
>
  <Header />
  <main class="mx-auto flex max-w-3xl flex-col items-center justify-center px-6 pb-24 pt-36 md:pt-44">
    <p class="mb-4 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">404</p>
    <h1 class="font-display text-3xl font-bold tracking-tight text-[var(--color-text)] md:text-4xl">
      Page Not Found
    </h1>
    <p class="mt-3 text-center text-[var(--color-text-muted)]">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 border border-[var(--color-border)] px-7 py-3.5 text-sm font-semibold text-[var(--color-text)] transition-all duration-200 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
      </svg>
      Back to Home
    </a>
  </main>
  <Footer />
  <BackToTop />
</Layout>
