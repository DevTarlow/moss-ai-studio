---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import BackToTop from "../../../components/BackToTop.astro";

export const getStaticPaths = (async ({ paginate }): Promise<any> => {
  const posts = await getCollection("blog");
  const sorted = posts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  const routes = paginate(sorted, { pageSize: 10 });
  return routes.filter((r) => r.params.page !== "1");
});

const { page } = Astro.props;
const prevUrl = page.currentPage === 2 ? "/blog/" : page.url.prev;
---

<Layout
  title={`Blog — Page ${page.currentPage} — Moss AI Studio`}
  description={`Articles about indie AI development, building software, and shipping products. Page ${page.currentPage} of ${page.lastPage}.`}
  canonical={`https://mossaistudio.com/blog/page/${page.currentPage}`}
>
  <Header />
  <main class="mx-auto max-w-6xl px-6 pb-24 pt-24 md:pt-32">
    <a
      href="/blog/"
      class="mb-10 inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-accent)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
      </svg>
      Back to Blog
    </a>

    <div class="mb-14 reveal">
      <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">Blog</p>
      <h1 class="font-display text-3xl font-bold tracking-tight text-[var(--color-text)] md:text-4xl">
        All Posts
      </h1>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {page.data.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class="group flex flex-col rounded-xl border border-[var(--color-border)] bg-white shadow-sm transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 reveal overflow-hidden"
          class:list={[`reveal-delay-${i + 1}`]}
        >
          {post.data.image ? (
            <div class="h-44 w-full bg-[var(--color-bg)]">
              <img src={post.data.image} alt={post.data.title} class="h-full w-full object-cover" loading="lazy" />
            </div>
          ) : (
            <div class="h-2 w-full bg-[var(--color-accent)]"></div>
          )}
          <div class="flex flex-1 flex-col p-6 md:p-8">
            <time datetime={post.data.pubDate.toISOString()} class="mb-2 block font-mono text-[10px] font-medium uppercase tracking-[0.15em] text-[var(--color-text-muted)]">
              {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </time>
            <h2 class="font-display text-xl font-bold leading-snug text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)] line-clamp-3">
              {post.data.summary}
            </p>
          </div>
        </a>
      ))}
    </div>

    <nav class="mt-12 flex items-center justify-center gap-4 reveal">
      <a
        href={prevUrl}
        class="inline-flex items-center gap-1.5 border border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text)] transition-all duration-200 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
        </svg>
        Prev
      </a>

      <span class="text-sm font-medium text-[var(--color-text-muted)]">
        {page.currentPage} / {page.lastPage}
      </span>

      {page.url.next ? (
        <a
          href={page.url.next}
          class="inline-flex items-center gap-1.5 border border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text)] transition-all duration-200 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >
          Next
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 0 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 0 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
          </svg>
        </a>
      ) : (
        <span class="inline-flex items-center gap-1.5 border border-[var(--color-border)]/40 px-5 py-2.5 text-sm font-semibold text-[var(--color-text-muted)]/40 cursor-not-allowed">
          Next
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 0 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 0 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
          </svg>
        </span>
      )}
    </nav>
  </main>
  <Footer />
  <BackToTop />
</Layout>
