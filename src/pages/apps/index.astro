---
import { products } from "../../data/products.js";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BackToTop from "../../components/BackToTop.astro";
import WaitlistModal from "../../components/WaitlistModal.astro";
---

<Layout
  title="All Products - Moss AI Studio - AI-powered tools and Automation software"
  description="Browse all AI-powered tools and automation software from Moss AI Studio."
  canonical="https://mossaistudio.com/apps/"
>
  <Header />
  <main class="mx-auto max-w-6xl px-6 pb-24 pt-24 md:pt-32">
    <a
      href="/#apps"
      class="mb-10 inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-accent)]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
        <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
      </svg>
      Back to Home
    </a>

    <div class="mb-14 reveal">
      <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">Our Products</p>
      <h1 class="font-display text-3xl font-bold tracking-tight text-[var(--color-text)] md:text-4xl">
        All Products
      </h1>
      <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">
        Ready-to-use tools. Built to take root.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {products.map((product, i) => (
        <div
          class="group flex flex-col rounded-xl border border-[var(--color-border)] bg-white shadow-sm transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 reveal overflow-hidden"
          class:list={[`reveal-delay-${i + 1}`]}
        >
          {product.image ? (
            <a href={`/apps/${product.slug}`} class="relative block h-44 w-full bg-[var(--color-bg)] overflow-hidden">
              <img src={product.image} alt={product.name} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
              {product.comingSoon && (
                <span class="absolute right-3 top-3 inline-flex items-center gap-1 rounded-full bg-[var(--color-accent-2)]/90 px-2.5 py-1 font-mono text-[10px] font-semibold uppercase tracking-wide text-white backdrop-blur-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clip-rule="evenodd" />
                  </svg>
                  Coming Soon
                </span>
              )}
            </a>
          ) : (
            <div class="flex h-44 w-full items-center justify-center bg-[var(--color-bg)]">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 80" fill="none" class="h-16 w-24">
                <rect x="4" y="4" width="112" height="72" rx="6" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-border)]" />
                <rect x="4" y="4" width="112" height="14" rx="6" fill="currentColor" class="text-[var(--color-border)]/40" />
                <circle cx="14" cy="11" r="2.5" fill="currentColor" class="text-[var(--color-text-muted)]/30" />
                <circle cx="21" cy="11" r="2.5" fill="currentColor" class="text-[var(--color-text-muted)]/30" />
                <circle cx="28" cy="11" r="2.5" fill="currentColor" class="text-[var(--color-text-muted)]/30" />
                <rect x="12" y="28" width="45" height="3" rx="1.5" fill="currentColor" class="text-[var(--color-border)]" />
                <rect x="12" y="36" width="60" height="3" rx="1.5" fill="currentColor" class="text-[var(--color-border)]/60" />
                <rect x="12" y="44" width="55" height="3" rx="1.5" fill="currentColor" class="text-[var(--color-border)]/60" />
                <rect x="12" y="52" width="70" height="3" rx="1.5" fill="currentColor" class="text-[var(--color-border)]/60" />
                <rect x="68" y="28" width="36" height="38" rx="4" stroke="currentColor" stroke-width="1.5" class="text-[var(--color-border)]" />
              </svg>
            </div>
          )}
          <div class="flex flex-1 flex-col p-8">
            <div class="mb-4 flex items-start justify-between gap-4">
                <h2 class="font-display text-xl font-bold text-[var(--color-text)]">
                  {product.name}
                </h2>
                <span class="inline-flex flex-shrink-0 items-center gap-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-3 py-1 font-mono text-[10px] font-medium text-[var(--color-text-muted)]">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3">
                    <path fill-rule="evenodd" d="M2 3.75A.75.75 0 0 1 2.75 3h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 3.75Zm0 4.167a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Zm0 4.166a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Zm0 4.167a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
                  </svg>
                  {product.platform}
                </span>
              </div>
              <p class="mb-4 text-sm leading-relaxed text-[var(--color-text-muted)]">{product.tagline}</p>

            <div class="mb-5 flex flex-col gap-2 text-sm">
              {product.pricing.map((tier) => (
                <span class="inline-flex items-center gap-2">
                  <span class:list={[
                    "inline-block rounded-full px-2.5 py-0.5 text-xs font-semibold",
                    tier.label === "Free"
                      ? "bg-[var(--color-accent)]/15 text-[var(--color-accent)]"
                      : "bg-[var(--color-text)]/8 text-[var(--color-text)]"
                  ]}>
                    {tier.price}{tier.period ? ` ${tier.period.replace("/", "").trim()}` : ""}
                  </span>
                  <span class="text-xs text-[var(--color-text-muted)]/60">{tier.description}</span>
                </span>
              ))}
            </div>

            <div class="mt-auto flex flex-wrap items-center gap-3">
              {product.comingSoon ? (
                <button
                  type="button"
                  data-waitlist-open=""
                  class="inline-flex cursor-pointer items-center gap-1.5 bg-[var(--color-accent)] px-5 py-2.5 text-sm font-bold uppercase tracking-wide text-[#0F172A] transition-all duration-200 hover:bg-[var(--color-accent-hover)] hover:scale-[1.02]"
                >
                  Notify Me
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                    <path fill-rule="evenodd" d="M10 2a6 6 0 0 0-6 6c0 1.887-.454 3.665-1.257 5.234a.75.75 0 0 0 .515 1.076 32.91 32.91 0 0 0 3.256.508 3.5 3.5 0 0 0 6.972 0 32.903 32.903 0 0 0 3.256-.508.75.75 0 0 0 .515-1.076A11.448 11.448 0 0 1 16 8a6 6 0 0 0-6-6ZM8.05 14.943a33.54 33.54 0 0 0 3.9 0 2 2 0 0 1-3.9 0Z" clip-rule="evenodd" />
                  </svg>
                </button>
              ) : product.externalBuy ? (
                <a
                  href={product.buyLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 bg-[var(--color-accent)] px-5 py-2.5 text-sm font-bold uppercase tracking-wide text-[#0F172A] transition-all duration-200 hover:bg-[var(--color-accent-hover)] hover:scale-[1.02]"
                >
                  Get License
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                    <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 0 0-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 0 0 .75-.75v-4a.75.75 0 0 1 1.5 0v4A2.25 2.25 0 0 1 12.75 17h-8.5A2.25 2.25 0 0 1 2 14.75v-8.5A2.25 2.25 0 0 1 4.25 4h5a.75.75 0 0 1 0 1.5h-5Z" clip-rule="evenodd" />
                    <path fill-rule="evenodd" d="M6.194 12.753a.75.75 0 0 0 1.06.053L16.5 4.44v2.81a.75.75 0 0 0 1.5 0v-4.5a.75.75 0 0 0-.75-.75h-4.5a.75.75 0 0 0 0 1.5h2.553l-9.056 8.194a.75.75 0 0 0-.053 1.06Z" clip-rule="evenodd" />
                  </svg>
                </a>
              ) : (
                <a
                  href={product.buyLink}
                  class="inline-flex items-center gap-1.5 bg-[var(--color-accent)] px-5 py-2.5 text-sm font-bold uppercase tracking-wide text-[#0F172A] transition-all duration-200 hover:bg-[var(--color-accent-hover)] hover:scale-[1.02]"
                >
                  Buy Now
                </a>
              )}
              <a
                href={`/apps/${product.slug}`}
                class="inline-flex items-center gap-1.5 border border-[var(--color-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-text)] transition-all duration-200 hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
              >
                Learn More
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <WaitlistModal />
  </main>
</Layout>
