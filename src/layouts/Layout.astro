---
export interface Props {
  title?: string;
  description?: string;
}

import "../styles/global.css";

const { title, description } = Astro.props;
const siteTitle = title ?? "Moss AI Studio — AI Automation & Engineering";
const siteDescription = description ?? "We automate workflows and build custom AI apps so startups and SMBs can focus on what matters. n8n, LLMs, and process automation engineering.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href="https://mossaistudio.com" />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />

    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mossaistudio.com" />
    <meta property="og:image" content="https://mossaistudio.com/images/moss-ai-studio-logo.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://mossaistudio.com/images/moss-ai-studio-logo.jpg" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Moss AI Studio",
        "description": "Tailored Automation & AI Systems for startups and SMBs. Custom workflows, AI app development, and process audits.",
        "url": "https://mossaistudio.com",
        "founder": {
          "@type": "Person",
          "name": "Tarlow P."
        },
        "areaServed": "US",
        "foundingLocation": "Portland, OR"
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-brand-cream text-brand-earth font-sans antialiased">
    <slot />
    <script>
      import "../scripts/reveal.js";
    </script>
  </body>
</html>
