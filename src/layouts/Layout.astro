---
export interface Props {
  title?: string;
  description?: string;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{Astro.props.title ?? "Moss AI Studio — AI Automation & Engineering"}</title>
    <meta
      name="description"
      content={Astro.props.description ?? "We automate workflows and build custom AI apps so startups and SMBs can focus on what matters. n8n, LLMs, and process automation engineering."}
    />

    <meta property="og:title" content={Astro.props.title ?? "Moss AI Studio — AI Automation & Engineering"} />
    <meta
      property="og:description"
      content={Astro.props.description ?? "We automate workflows and build custom AI apps so startups and SMBs can focus on what matters."}
    />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-brand-cream text-brand-earth font-sans antialiased">
    <slot />
    <script>
      import "../scripts/reveal.js";
    </script>
  </body>
</html>
